@echo off
chcp 65001 >nul
echo ----------------------------------------
echo ปิดเซิร์ฟเวอร์เก่าที่ค้างอยู่ (Port 3000)...
echo ----------------------------------------
for /f "tokens=5" %%a in ('netstat -aon ^| find ":3000" ^| find "LISTENING"') do (
    echo พบเซิร์ฟเวอร์เก่ากำลังทำงานที่ PID: %%a... กำลังปิด...
    taskkill /F /PID %%a >nul 2>&1
)

echo.
echo ----------------------------------------
echo กำลังเริ่มต้นเซิร์ฟเวอร์เวอร์ชันใหม่ล่าสุด...
echo ----------------------------------------
node server.js
pause
